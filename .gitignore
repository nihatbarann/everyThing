# ============================================
# EveryThing Project — .gitignore
# ============================================

# ---- PHP / Backend ----
# Auto-generated by the install wizard — contains real DB credentials
backend/config/database.php

# PHP error logs
*.log
error_log

# ---- Node / Frontend ----
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ---- OS & Editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.user

# ---- Apache ----
# If you store local Apache config here, exclude it
*.conf.local
