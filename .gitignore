# ============================================
# EveryThing — .gitignore
# ============================================

# ── PHP / Backend ───────────────────────────
# Auto-generated by install wizard (contains real DB credentials)
backend/config/database.php

# Created after successful setup — prevents re-installation
backend/config/install.lock

# System config (theme, etc.) — user-specific
backend/config/system.json

# Auto-generated JWT signing secret (unique per installation)
backend/config/jwt_secret.php

# PHP error logs
*.log
error_log
backend/error.log

# ── Node / Frontend ─────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ── OS & Editor ─────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.user

# ── Apache ──────────────────────────────────
*.conf.local
.htpasswd
